# Rust
/target/
**/*.rs.bk
# Cargo.lock is committed for this binary-producing workspace (P1 decision).

# Foundry
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/lib/*
# forge-std is vendored at v1.16.1 (MIT/Apache-2.0). Keeps CI hermetic and
# avoids forge-CLI flag-rename traps (see commit message for context).
!contracts/lib/forge-std

# Node (extension, desktop UI)
node_modules/
.pnpm-store/
dist/
build/
.next/
.turbo/

# Tauri
apps/desktop/src-tauri/target/

# Mobile
apps/ios/build/
apps/ios/DerivedData/
apps/ios/Pods/
apps/android/build/
apps/android/.gradle/
apps/android/local.properties

# Editors
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Secrets — never commit
.env
.env.*
!.env.example
# MVP-2 issue 2.3: per-environment contract deploy configs are committed
# (dev + sepolia have no secrets; mainnet ships only as a template). The
# real .env.mainnet (filled in just-in-time by Kelvin) stays ignored.
!contracts/deploy/.env.dev
!contracts/deploy/.env.sepolia
!contracts/deploy/.env.mainnet.template
contracts/deploy/.env.mainnet
# Issue #98 (L5): the pre-release live-test runner sources this for
# RPC URL + keystore path + wallet address. Already covered by the
# wildcard above; named explicitly so future readers know what it is.
.env.live
*.pem
*.key
secrets/
deployments/*.local.json
# Issue #101 (R-e): the anvil-fork CI harness (scripts/anvil-ci.sh)
# generates contracts/deployments/dev.json at runtime from the fresh
# local deploy. It is true-by-construction per run and MUST NOT be
# committed (a stale fixture would point tests at a dead address).
contracts/deployments/dev.json
# Pangolin vault files (encrypted user data — never commit even though
# the AEAD-sealed contents are protected at rest; metadata + structure
# would still leak, and a committed vault surprises verifiers)
*.pvf
*.pvf-wal
*.pvf-shm
*.pvf.lock

# Release artifacts produced by scripts/release-windows.ps1. The zip lives
# at repo root by convention (per scripts/release-windows.ps1 §A12); the
# binaries themselves are gitignored under dist/ above.
pangolin-poc-*.zip

# Test artifacts
*.profraw
coverage/

# OS
.DS_Store
Thumbs.db
