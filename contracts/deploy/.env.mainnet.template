# Pangolin contract deploy: Base mainnet — TEMPLATE.
#
# Source of truth: docs/issue-plans/2.3.md L2 + L6 (mainnet gate). This
# is a TEMPLATE; copy it to .env.mainnet and fill in the required values
# BEFORE deploying. .env.mainnet is .gitignored — never commit the real
# values.
#
# Mainnet deploy is gated on D-011 (external audit). The wrapper script
# additionally refuses to proceed unless PANGOLIN_MAINNET_AUDITED=1 is
# set in the deploy shell (L6 soft gate).

# Required at deploy time. Use a private RPC (Alchemy / Infura) for
# mainnet — the free public endpoint is rate-limited and unreliable
# for production deploys.
RPC_URL="${BASE_MAINNET_RPC_URL:-}"

# Base mainnet chain id (D-005).
EXPECTED_CHAIN_ID=8453

# Create a separate keystore alias for mainnet — DO NOT reuse pangolin-dev.
# Hardware-wallet-backed alias is strongly preferred (e.g.,
# `cast wallet new --ledger` or import from a Ledger). The runbook
# (docs/RELEASE-CONTRACTS.md) covers the keystore-creation steps.
DEPLOYER_ACCOUNT="pangolin-mainnet"

# Required: supplied by Kelvin's billing infrastructure (payment
# authority) and the funder service operators (redemption authority).
# These are NEVER the same address in production (L8 collapse applies
# to testnet only).
PAYMENT_AUTHORITY=""
REDEMPTION_AUTHORITY=""

# Basescan verifier URL for mainnet (no -sepolia suffix). Same API key
# as the Sepolia env var.
VERIFIER_URL="https://api.basescan.org/api"
BASESCAN_API_KEY="${BASESCAN_API_KEY:-}"

# Minimum deployer balance: 0.1 ETH (mainnet gas is materially higher
# than testnet). Verify before deploying.
MIN_DEPLOYER_BALANCE_WEI=100000000000000000
