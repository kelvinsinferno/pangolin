# Pangolin contract deploy: dev environment (local anvil).
#
# Source of truth: docs/issue-plans/2.3.md L2 (per-env dotenv files) +
# the sketch in §2 of that plan. Sourced by scripts/deploy-contracts.sh
# when invoked with --env dev.
#
# Safe to commit: only references local anvil + dummy authority
# addresses. No keys, no API keys.

# Local anvil RPC. Override with BASE_DEV_RPC_URL if running anvil on
# a non-default host/port.
RPC_URL="${BASE_DEV_RPC_URL:-http://127.0.0.1:8545}"

# anvil's chain id is 31337 by default.
EXPECTED_CHAIN_ID=31337

# anvil's first prefunded account (address derived from the well-known
# anvil mnemonic). Anvil reports it as "Available Accounts" #(0) on
# startup. NOT a real keystore alias — for real deploys use
# --env sepolia or --env mainnet.
DEPLOYER_ACCOUNT="anvil-default"

# Dummy authority addresses for EntitlementRegistry constructor
# (the constructor's address(0) zero-authority guard will trip if
# unset; these are the same dummies the CI dry-run uses).
PAYMENT_AUTHORITY="0x0000000000000000000000000000000000000001"
REDEMPTION_AUTHORITY="0x0000000000000000000000000000000000000002"

# No Basescan verification on a local fork. Wrapper checks for empty
# BASESCAN_API_KEY and skips the --verify flag accordingly.
VERIFIER_URL=""
BASESCAN_API_KEY=""
