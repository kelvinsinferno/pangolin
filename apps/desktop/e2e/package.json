{
  "name": "@pangolin/desktop-e2e",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Pangolin desktop end-to-end UX gate — WebDriverIO + tauri-driver. See docs/issue-plans/mvp4-f-desktop-e2e.md.",
  "engines": {
    "node": ">=20.18.0 <23"
  },
  "scripts": {
    "build:fixture": "tsx setup/build-fixture-vault.ts",
    "build:desktop": "cargo build -p pangolin-desktop --features test-hooks,custom-protocol",
    "wdio": "wdio run wdio.conf.ts",
    "e2e": "tsx setup/build-fixture-vault.ts && cargo build -p pangolin-desktop --features test-hooks,custom-protocol && wdio run wdio.conf.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"specs/**/*.ts\" \"setup/**/*.ts\" \"wdio.conf.ts\""
  },
  "devDependencies": {
    "@types/chai": "=5.0.1",
    "@types/mocha": "=10.0.10",
    "@types/node": "=20.17.10",
    "@typescript-eslint/eslint-plugin": "=8.18.0",
    "@typescript-eslint/parser": "=8.18.0",
    "@wdio/cli": "=9.27.2",
    "@wdio/globals": "=9.27.2",
    "@wdio/local-runner": "=9.27.2",
    "@wdio/mocha-framework": "=9.27.2",
    "@wdio/spec-reporter": "=9.27.2",
    "@wdio/types": "=9.27.2",
    "chai": "=5.1.2",
    "eslint": "=9.17.0",
    "mocha": "=11.0.1",
    "tsx": "=4.19.2",
    "typescript": "=5.7.2",
    "webdriverio": "=9.27.2"
  }
}
